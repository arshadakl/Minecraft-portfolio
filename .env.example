# Contact form email delivery (Gmail SMTP).
# Copy this file to .env.local and fill in real values.

# The Gmail address that sends AND receives the contact messages.
GMAIL_USER=you@gmail.com

# A Google App Password (NOT your normal Gmail password).
# Generate one at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification enabled). Paste it without spaces.
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
